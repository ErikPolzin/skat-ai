# Skat AI - Environment Variables Configuration
# Copy this file to .env and customize for your environment

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================

# HTTP server port (default: 8080)
PORT=8080

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# PostgreSQL database host (default: localhost)
DB_HOST=localhost

# PostgreSQL database port (default: 5432)
DB_PORT=5432

# PostgreSQL database user (default: postgres)
# For Docker testing, use: skat_user
DB_USER=postgres

# PostgreSQL database password (REQUIRED for database persistence)
# Leave empty to run without database (memory-only mode)
# For Docker testing, use: skat_password
DB_PASSWORD=

# PostgreSQL database name (default: skat)
# For Docker testing, use: skat_db
DB_NAME=skat

# PostgreSQL SSL mode: disable, require, verify-ca, verify-full (default: disable)
DB_SSLMODE=disable

# =============================================================================
# Q-TABLE STORAGE - LOCAL FILES
# =============================================================================

# Path to JSON Q-table file (default: bidding_qtable.json)
QTABLE_JSON_PATH=bidding_qtable.json

# Path to binary Q-table file (default: bidding_qtable.gob)
QTABLE_BINARY_PATH=bidding_qtable.gob

# Storage format: "json" or "binary" (default: binary)
# Binary is 66% smaller and faster to load
QTABLE_FORMAT=binary

# =============================================================================
# Q-TABLE STORAGE - GOOGLE CLOUD STORAGE
# =============================================================================

# GCS bucket name (if set, enables GCS storage)
# Example: my-skat-models
# Leave empty to use local file storage only
GCS_BUCKET=

# GCS authentication methods (choose one):
#
# Method 1: Application Default Credentials (recommended for local dev)
#   Run: gcloud auth application-default login
#
# Method 2: Service Account Key (recommended for production)
#   Set: export GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json
#
# Method 3: Workload Identity (automatic in GKE/Cloud Run)
#   No configuration needed when running on GCP

# =============================================================================
# TRAINING CONFIGURATION
# =============================================================================

# Number of training episodes (overrides defaults in training scripts)
# TRAINING_EPISODES=10000

# Learning rate (alpha) for Q-learning
# LEARNING_RATE=0.1

# Discount factor (gamma) for Q-learning
# DISCOUNT_FACTOR=0.9

# Initial exploration rate (epsilon)
# INITIAL_EPSILON=0.15

# Minimum exploration rate
# MIN_EPSILON=0.05

# =============================================================================
# AGENT CONFIGURATION
# =============================================================================

# MCTS simulation count per move
# MCTS_SIMULATIONS=500

# MCTS determinizations (for imperfect information handling)
# MCTS_DETERMINIZATIONS=10

# =============================================================================
# USAGE EXAMPLES
# =============================================================================

# Example 1: Local development with binary format
#   PORT=8080
#   QTABLE_FORMAT=binary
#   QTABLE_BINARY_PATH=bidding_qtable.gob
#
# Example 2: Production with GCS storage
#   PORT=8080
#   GCS_BUCKET=my-skat-models
#   GCS_QTABLE_PATH=qtables/bidding_v2.gob
#   QTABLE_FORMAT=binary
#   GOOGLE_APPLICATION_CREDENTIALS=/app/credentials/gcs-key.json
#
# Example 3: Training environment saving to GCS
#   TRAINING_EPISODES=10000
#   GCS_BUCKET=my-skat-models
#   GCS_QTABLE_PATH=qtables/bidding_$(date +%Y%m%d).gob
#   QTABLE_FORMAT=binary
#
# Example 4: JSON format for debugging
#   QTABLE_FORMAT=json
#   QTABLE_JSON_PATH=debug_qtable.json

# =============================================================================
# NOTES
# =============================================================================

# File size comparison:
#   JSON:   ~2897 bytes (human-readable, portable)
#   Binary: ~973 bytes (66.4% smaller, faster, Go-only)
#
# GCS bucket setup:
#   1. Create bucket: gsutil mb gs://my-skat-models
#   2. Set permissions: gsutil iam ch serviceAccount:xxx@xxx.iam.gserviceaccount.com:objectAdmin gs://my-skat-models
#   3. Test access: gsutil ls gs://my-skat-models
#
# Loading priority:
#   1. If GCS_BUCKET is set → load from GCS
#   2. Otherwise → load from local file (JSON or binary based on QTABLE_FORMAT)
#
# Saving behavior:
#   - Always saves to local file first
#   - If GCS_BUCKET is set, also uploads to GCS
#   - This ensures redundancy and local backups
